# Copy to .env for local runs (`set dotenv-load` in the justfile picks it up).
# All values are also CLI flags (see `supervisord --help`).

# Mesh coordinator control-plane URL. Default bakes the prod EIP.
TABBIFY_MESH_COORDINATOR=http://3.124.69.92:8888

# Control/serve listener. In production the binary binds [my_ula]:8730 from the
# mesh join automatically; set SUPERVISOR_BIND only to pin a loopback addr for
# local testing (e.g. with --no-mesh).
# SUPERVISOR_BIND=127.0.0.1:8730
SUPERVISOR_PORT=8730

# Local cache dir for fetched app artifacts.
SUPERVISOR_DATA_DIR=./data

# S3 base for anonymous artifact fetch. Override for a local mock.
SUPERVISOR_S3_BASE_URL=https://tabbify-apps.s3.eu-central-1.amazonaws.com

# Display name advertised to the coordinator.
SUPERVISOR_NAME=tabbify-supervisor

# Skip the mesh join entirely (loopback only, no TUN/root). Default off.
# SUPERVISOR_NO_MESH=true

# Logging.
RUST_LOG=info,tabbify_supervisor=debug,supervisord=debug
